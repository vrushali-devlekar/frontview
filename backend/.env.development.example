NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/velora
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-session-secret
ENCRYPTION_KEY=replace-with-64-char-hex-key

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false

GITHUB_CLIENT_ID=your-dev-github-client-id
GITHUB_CLIENT_SECRET=your-dev-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

GOOGLE_CLIENT_ID=your-dev-google-client-id
GOOGLE_CLIENT_SECRET=your-dev-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

MISTRAL_API_KEY=
COHERE_API_KEY=
GEMINI_API_KEY=
